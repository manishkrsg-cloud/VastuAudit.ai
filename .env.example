# ============================================================================
# VastuAudit.ai — environment variables
# Copy this file to .env (root) for orchestration, or to apps/api/.env / apps/web/.env.local
# ============================================================================

# -- App identity ---------------------------------------------------------
APP_NAME=VastuAudit.ai
APP_OWNER=Qadr AI Agency Dubai
APP_ENV=development          # development | staging | production
ADMIN_EMAIL=manish@qadr.ai

# -- Database / cache -----------------------------------------------------
DATABASE_URL=postgresql+asyncpg://vastuaudit:vastuaudit@localhost:5432/vastuaudit
REDIS_URL=redis://localhost:6379/0

# -- AI -------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
# Note: brief said "claude-sonnet-4-7" but that model does not exist.
# Latest Sonnet is 4.6; Opus is 4.7. Use Sonnet 4.6 as default.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_REASONING_MODEL=claude-opus-4-7

# -- Auth (Clerk) ---------------------------------------------------------
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=          # Svix signing secret from Clerk dashboard

# -- Storage (Cloudflare R2 — S3 compatible) ------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vastuaudit-plans
R2_PUBLIC_BASE_URL=            # e.g. https://plans.vastuaudit.ai

# -- Payments (Stripe) ----------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_ID=
STRIPE_PRICE_CONSULTANT_ID=

# -- Email (Resend) -------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@vastuaudit.ai

# -- Frontend -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Observability --------------------------------------------------------
SENTRY_DSN=
POSTHOG_API_KEY=

# -- API config -----------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,https://vastuaudit.ai
LOG_LEVEL=INFO
