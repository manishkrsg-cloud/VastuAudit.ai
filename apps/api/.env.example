ANTHROPIC_REASONING_MODEL=claude-opus-4-7

CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vastuaudit-plans
R2_PUBLIC_BASE_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_ID=
STRIPE_PRICE_CONSULTANT_ID=

RESEND_API_KEY=
