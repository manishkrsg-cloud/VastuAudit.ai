# See repo-root .env.example for the canonical list. This file mirrors only
# the variables the API process consumes directly.

APP_NAME=VastuAudit.ai
APP_OWNER=Qadr AI Agency Dubai
APP_ENV=development
ADMIN_EMAIL=manish@qadr.ai
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://vastuaudit:vastuaudit@localhost:5432/vastuaudit
REDIS_URL=redis://localhost:6379/0

ANTHROPIC_API_KEY=sk-ant-...
